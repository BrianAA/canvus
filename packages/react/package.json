  "devDependencies": {
    "@canvus/core": ">=0.1.0",
    "@types/react": "^18.0.0",
    "@types/react-dom": "^18.0.0",
    "react": "^18.0.0",
    "react-dom": "^18.0.0",
    "typescript": "^5.8.3"
  },
  "license": "MIT"
