{"nodes": [{"id": "architecture_guidelines", "label": "Developer Guidelines & Constraints", "file_type": "document", "source_file": "docs-site/pages/architecture/guidelines.mdx", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null}, {"id": "architecture_guidelines_framework_independence", "label": "Framework Independence", "file_type": "rationale", "source_file": "docs-site/pages/architecture/guidelines.mdx", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Ensure the SDK core remains 100% vanilla TypeScript. No React, Vue, Svelte, or other UI framework dependencies are permitted."}, {"id": "architecture_guidelines_strict_styling_isolation", "label": "Strict Styling Isolation", "file_type": "rationale", "source_file": "docs-site/pages/architecture/guidelines.mdx", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Never apply styles directly inside ShadowMount that could bleed or pollute the host. All reset rules belong in SHADOW_RESET_CSS."}, {"id": "architecture_guidelines_flat_string_exports", "label": "Pristine Flat String Exports", "file_type": "rationale", "source_file": "docs-site/pages/architecture/guidelines.mdx", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Any new wrapper classes, metadata attributes, or alignment markers must be filtered out in ShadowMount.extractHTML to ensure the consumer receives clean user markup."}, {"id": "architecture_guidelines_raf_throttled_rendering", "label": "rAF-Throttled Rendering", "file_type": "rationale", "source_file": "docs-site/pages/architecture/guidelines.mdx", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Canvas overlay drawings must never run synchronously; queue them on the next animation fra